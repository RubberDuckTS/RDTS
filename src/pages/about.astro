---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import headshot from '../assets/long-headshot.webp';

const title = 'About Long Nguyen — founder of RDTS';
const description = 'I\'m Long. Nearly a decade writing production code, since 2018 — pre-LLM. I install your AI environment: skills, agents, integrations, the harness your team actually uses. Solo studio in Missouri.';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Long Nguyen',
  url: 'https://www.rubberducktechsolutions.com/about/',
  image: 'https://www.rubberducktechsolutions.com/long-headshot.jpg',
  jobTitle: 'Founder & Engineer',
  worksFor: {
    '@type': 'Organization',
    name: 'Rubber Duck Tech Solutions',
    legalName: 'Long Win LLC',
    url: 'https://www.rubberducktechsolutions.com/',
  },
  knowsAbout: [
    'Claude Code setup',
    'Cursor setup',
    'Codex setup',
    'OpenClaw setup',
    'Claude skills',
    'MCP servers',
    'Agent harnesses',
    'Anthropic Claude API',
    'OpenAI API',
    'Custom AI agents',
    'Astro',
    'TypeScript',
    'Node.js',
    'PostgreSQL',
    'Supabase',
  ],
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'MO',
    addressCountry: 'US',
  },
  sameAs: [
    'https://www.linkedin.com/in/long-nguyen-a3b6326a/',
    'https://github.com/LongPNguyen',
  ],
};
---

<BaseLayout title={title} description={description} schema={personSchema}>
  {/* HERO */}
  <section class="section-dark">
    <div class="container-x pt-20 lg:pt-28 pb-12 lg:pb-16">
      <div class="grid grid-cols-12 gap-x-8 gap-y-8 items-center">
        <div class="col-span-12 lg:col-span-8">
          <div class="status-pill mb-6"><span class="status-pill__dot"></span><span>Available · 1 of 2 slots · 2026 Q2</span></div>
          <h1 class="display-h1 mb-6 max-w-[18ch]">
            I'm <span class="accent-saffron">Long</span>.<br/>
            I install your<br/>
            <span class="underline-saffron">AI environment</span><span class="cursor"></span>
          </h1>
          <p class="text-[18px] text-bone-dim leading-[1.6] max-w-[58ch]">
            Solo founder of RDTS. Nearly a decade writing production software — started in 2018,
            before Midjourney existed and well before LLMs could ship usable code. Spent the agency
            years as the in-house dev other teams called when their tools stopped working the way
            their work actually worked. Went solo to set that up properly, on purpose, for whoever
            needs it.
          </p>
        </div>
        <div class="hidden lg:flex col-span-4 justify-end">
          <div class="relative w-full max-w-[300px] aspect-[4/5] overflow-hidden rounded-soft border border-ink-border">
            <Image
              src={headshot}
              alt="Long Nguyen, founder of Rubber Duck Tech Solutions"
              widths={[300, 600]}
              sizes="(min-width: 1024px) 300px, 100vw"
              format="webp"
              quality={82}
              class="w-full h-full object-cover object-[70%_center]"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* STORY */}
  <Section tone="cream" label="The story">
    <div class="grid grid-cols-12 gap-x-12 gap-y-8">
      <div class="col-span-12 lg:col-span-8 lg:col-start-3">
        <div class="prose-rdts">
          <p>
            I started writing software for a living in 2018 — before Midjourney existed, before
            ChatGPT existed, before LLMs could write usable code. I came up traditional: real backends,
            real frontends, real databases, no AI lifting the keyboard for me. By the time the first
            useful LLMs landed in 2022 I had four years of production-grade code under my belt and a
            very clear sense of what AI was good for and what it wasn't.
          </p>

          <p>
            I spent those early years as the in-house web developer at two marketing
            agencies — first as a junior, then as the engineer the founder went to when something had
            to actually work. Both shops sold creative work as the headline product. Both quietly
            depended on whatever automation glue I could rig up to make the operational side stay
            standing.
          </p>

          <p>
            What I kept watching, at both shops and at every team I've worked with since, is the same
            scene. Someone pays for ChatGPT Teams or Claude. A couple of people on the team use it
            constantly. Most don't touch it. The tools don't know the company's work. Each person
            who uses them does it differently. Nobody on the team actually knows what's possible. So
            the seat licenses go on the budget review and the work goes on being done the way it was
            done before.
          </p>

          <p>
            That gap isn't a "your people need more training" problem. It's a setup problem. The
            harness (Claude Code, Cursor, Codex, OpenClaw, whatever fits the team) needs skills that
            know your codebase, your clients, your standards. It needs MCP servers wired into the
            tools you already pay for. It needs agents that can actually do the work, not just
            describe it. None of that is the buyer's job to figure out.
          </p>

          <p>
            That's RDTS. I install your AI environment — skills, agents, integrations, the whole
            stack — configured for the way your team actually operates. Harness-agnostic,
            model-agnostic, opinionated about matching the right pieces to the use case.
          </p>

          <p>
            I also build custom software and websites when the duck spots that's what you
            actually need. The setup work is the wedge, but if you describe the problem and it
            turns out you need an app, not a stack — I build the app. Same engineer, same fixed
            pricing, source code yours on day one.
          </p>

          <p>
            <a href="/talk">Talk to the duck</a> if you want to hear what that looks like for your
            specific situation.
          </p>
        </div>
      </div>
    </div>
  </Section>

  {/* WHAT I BELIEVE */}
  <Section tone="dark" label="What I believe">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {[
        ['The tools aren\'t the problem.', 'Most teams already pay for the right AI tools. They\'re just installed wrong, configured wrong, or sitting next to the actual work instead of inside it.'],
        ['Harness-agnostic, on purpose.', 'Claude Code, Cursor, Codex, OpenClaw, Cline, Aider — they\'re all good for something. I pick the one that fits the team and the work, not the one I have a discount code for.'],
        ['Source code transfers to you.', 'Skills, agents, MCP servers, software builds — all of it ships into your repo, your infra, your accounts. Take it anywhere later.'],
        ['Solo, on purpose.', 'No agency layer between you and the engineer. The person you talk to first is the person doing the setup. That\'s the entire point.'],
        ['Specific over generic.', 'I tell you which harness, which model, which integration — and why. You hire me for opinions, not vibes.'],
        ['Honest no-list.', 'Foundation-model pre-training and cleared work — I refer those out. Everything else in the AI setup lane, I\'ll quote honestly.'],
      ].map(([head, body]) => (
        <div class="card-dark p-6">
          <h3 class="text-[18px] font-semibold tracking-tight2 text-bone mb-2">{head}</h3>
          <p class="text-[14px] text-bone-dim leading-[1.6]">{body}</p>
        </div>
      ))}
    </div>
  </Section>

  {/* CREDIBILITY MARKERS */}
  <Section tone="cream" label="The receipts">
    <div class="grid grid-cols-12 gap-x-8 gap-y-10">
      <div class="col-span-12 lg:col-span-5">
        <h2 class="display-h2 mb-5">Real builds.<br/>Not lorem ipsum.</h2>
        <p class="text-[15px] text-coal-dim leading-[1.65] max-w-[44ch] mb-6">
          The clearest signal of "is this person actually a working engineer?" is real software with
          real users. Three projects worth pointing at:
        </p>
      </div>

      <div class="col-span-12 lg:col-span-7 space-y-5">
        <div class="card-cream p-6">
          <div class="flex items-baseline justify-between mb-2">
            <h3 class="text-[24px] font-semibold tracking-tight2 text-coal">ClipMango</h3>
            <span class="font-mono text-[11px] tracking-spec uppercase text-coal-mute">solo · ongoing</span>
          </div>
          <p class="text-[15px] text-coal-dim leading-[1.65]">
            AI music video pipeline. Multi-model orchestration across Claude (lyric understanding),
            OpenAI (generation), and Seedance (video). Production-grade lip-sync, beat-detection,
            shot-by-shot prompt engineering. Strongest demo of what's actually possible end-to-end.
          </p>
        </div>

        <div class="card-cream p-6">
          <div class="flex items-baseline justify-between mb-2">
            <h3 class="text-[24px] font-semibold tracking-tight2 text-coal">Lee De Card</h3>
            <span class="font-mono text-[11px] tracking-spec uppercase text-coal-mute">lead dev · 2024</span>
          </div>
          <p class="text-[15px] text-coal-dim leading-[1.65]">
            AI-driven creator booking platform. Calendar integration, automated outreach, intake
            workflows. Built on a small team where I owned the engineering side end-to-end.
          </p>
        </div>

        <div class="card-cream p-6">
          <div class="flex items-baseline justify-between mb-2">
            <h3 class="text-[24px] font-semibold tracking-tight2 text-coal">Dragon Wagons</h3>
            <span class="font-mono text-[11px] tracking-spec uppercase text-coal-mute">site + tooling · 2024</span>
          </div>
          <p class="text-[15px] text-coal-dim leading-[1.65]">
            Marketing site + content automation backend. The kind of "we need a real engineer for the
            ops layer behind our public-facing site" project that's a textbook RDTS engagement.
          </p>
        </div>
      </div>
    </div>
  </Section>

  {/* CONTACT / CTA */}
  <Section tone="dark">
    <div class="grid grid-cols-12 gap-x-8 gap-y-8 items-center">
      <div class="col-span-12 lg:col-span-7">
        <div class="label mb-4">Reach me</div>
        <h2 class="display-h2 mb-5">
          Easiest way<br/>
          is to <span class="accent-saffron">talk</span>.
        </h2>
        <p class="text-[16px] text-bone-dim leading-[1.65] max-w-[58ch] mb-7">
          Describe your setup, your team, your stuck point. The duck reads the shape, names a price
          in plain English, and sends a scoping brief to you and to me. Five minutes, no funnel.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/talk/" class="btn btn-primary">Talk to the duck →</a>
          <a href="/contact/" class="btn btn-outline-light">Email instead</a>
        </div>
      </div>
      <div class="col-span-12 lg:col-span-5">
        <div class="card-dark p-6">
          <div class="label label--dim mb-4">Vitals</div>
          <dl class="space-y-3 text-[14px]">
            <div class="flex justify-between gap-4 border-b border-ink-border pb-3"><dt class="text-bone-mute">Name</dt><dd class="text-bone font-medium">Long Nguyen</dd></div>
            <div class="flex justify-between gap-4 border-b border-ink-border pb-3"><dt class="text-bone-mute">Studio</dt><dd class="text-bone font-medium">RDTS / Long Win LLC</dd></div>
            <div class="flex justify-between gap-4 border-b border-ink-border pb-3"><dt class="text-bone-mute">Based</dt><dd class="text-bone font-medium">Missouri, US</dd></div>
            <div class="flex justify-between gap-4 border-b border-ink-border pb-3"><dt class="text-bone-mute">Working solo</dt><dd class="text-bone font-medium">Yes</dd></div>
            <div class="flex justify-between gap-4 border-b border-ink-border pb-3"><dt class="text-bone-mute">Primary work</dt><dd class="text-bone font-medium text-right">AI environment setup</dd></div>
            <div class="flex justify-between gap-4"><dt class="text-bone-mute">Also builds</dt><dd class="text-bone font-medium text-right">custom software<br/>and websites</dd></div>
          </dl>
          <div class="flex gap-3 mt-5 pt-4 border-t border-ink-border">
            <a href="https://www.linkedin.com/in/long-nguyen-a3b6326a/" target="_blank" rel="noopener" class="btn btn-outline-light text-[13px] py-2 px-4">LinkedIn</a>
            <a href="https://github.com/LongPNguyen" target="_blank" rel="noopener" class="btn btn-outline-light text-[13px] py-2 px-4">GitHub</a>
          </div>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
