---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const title = 'Contact RDTS — prefer to skip the duck? | Rubber Duck Tech Solutions';
const description = 'The duck is the main intake. If you would rather email or book a call directly, here are the links. Long replies within a business day.';

const calendlyUrl = 'https://calendly.com/nguy4227/let-s-connect-project-role-or-collaboration';
---

<BaseLayout title={title} description={description}>
  <section class="section-dark">
    <div class="container-x pt-20 lg:pt-28 pb-12 lg:pb-16">
      <div class="status-pill mb-6"><span class="status-pill__dot"></span><span>Available · 1 of 2 slots · 2026 Q2</span></div>
      <h1 class="display-h1 mb-6 max-w-[20ch]">
        Prefer to skip<br/>
        the <span class="accent-saffron">duck</span>?
      </h1>
      <p class="text-[18px] text-bone-dim leading-[1.6] max-w-[58ch]">
        The duck is the main way in. Five minutes, it reads what you're trying to set up, quotes
        the shape in plain English, and sends a scoping brief to both of us. It's faster than
        email and it gets to a number sooner. If you'd still rather not, the two links below work.
      </p>
    </div>
  </section>

  <Section tone="cream">
    <div class="grid grid-cols-12 gap-x-8 gap-y-6">
      <div class="col-span-12 lg:col-span-8 lg:col-start-3">
        <div class="card-cream p-7 lg:p-8 mb-5">
          <div class="font-mono text-[10px] tracking-spec uppercase text-coal-mute mb-3">Email</div>
          <h2 class="text-[26px] font-semibold tracking-tight2 text-coal mb-3">
            <a href="mailto:long@rubberducktechsolutions.com" class="link-coal">long@rubberducktechsolutions.com</a>
          </h2>
          <p class="text-[15px] text-coal-dim leading-[1.65]">
            Tell me what you're trying to set up, who's on the team, and your rough budget. I read
            everything and reply within a business day. If you're emailing because the duck broke,
            mention that.
          </p>
        </div>

        <div class="card-cream p-7 lg:p-8 mb-8">
          <div class="font-mono text-[10px] tracking-spec uppercase text-coal-mute mb-3">Book a call</div>
          <h2 class="text-[26px] font-semibold tracking-tight2 text-coal mb-3">30 minutes, calendar straight to mine</h2>
          <p class="text-[15px] text-coal-dim leading-[1.65] mb-5">
            For when you'd rather talk than type. Pick a slot, no email back-and-forth.
          </p>
          <a
            href={calendlyUrl}
            target="_blank"
            rel="noopener"
            class="btn btn-outline-dark text-[14px]"
          >Open Calendly →</a>
        </div>

        <div class="text-center">
          <a href="/talk/" class="btn btn-primary">Or talk to the duck →</a>
          <p class="text-[13px] text-coal-mute mt-4">
            Honestly, the duck is faster. It already knows the shapes I work in.
          </p>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
