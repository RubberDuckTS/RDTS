---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const title = "RDTS — AI consultant & developer | custom software, AI integration, training";
const description = "An AI-focused developer and consultant for growing companies. I build and maintain custom software and websites, wire in AI, and train teams to use it — project or retainer.";

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Rubber Duck Tech Solutions',
  url: 'https://www.rubberducktechsolutions.com/',
  description,
};

const shapes = [
  {
    tag: '01 · build & maintain',
    head: 'You need something built — or kept running.',
    body: 'A custom app, an internal tool, a website, a dashboard, an integration — with AI baked in where it earns its place. New build or ongoing upkeep of what you already have. I ship it and I maintain it.',
    href: '/talk/',
  },
  {
    tag: '02 · AI integration & automation',
    head: 'You want AI wired into how you already work.',
    body: 'Automations, agents, and LLM features connected to the systems you already pay for — CRM, repos, support, drives. Not a demo environment. Real work moved off your team\'s plate.',
    href: '/talk/',
  },
  {
    tag: '03 · ongoing AI partner',
    head: 'You want a senior AI person, not a full-time hire.',
    body: 'On retainer, I own your AI direction — vet the tools, run the experiments, train the team, keep the stack current. One accountable person instead of a head-of-AI hire you can\'t justify yet.',
    href: '/talk/',
  },
];

const capabilities = [
  {
    no: '01',
    title: 'Signal filtering',
    desc: 'A new model or tool drops every week. I read the releases, run the evals, and tell you which three actually matter — so you\'re not reacting to every announcement.',
  },
  {
    no: '02',
    title: 'Stack decisions',
    desc: 'Which model for which job. Which agent framework is actually production-ready. Which integrations are worth the implementation cost. Opinionated recommendations, not a list of options.',
  },
  {
    no: '03',
    title: 'Agents & automation',
    desc: 'Long-running, tool-using agents that own the repeated work — research, content drafts, ops triage, code review. Scoped to what your team actually does. See <a href="/services/ai-automation-agency/" class="link-coal">AI automation</a>.',
  },
  {
    no: '04',
    title: 'Integrations',
    desc: 'MCP servers and API wiring into the systems you already pay for — CRM, CMS, analytics, support, repos, drives. Connected to your stack, not a demo environment. See <a href="/services/ai-developer-for-hire/" class="link-coal">AI consulting</a>.',
  },
  {
    no: '05',
    title: 'Monthly retainer',
    desc: 'One person, on retainer, keeping up with AI so your team doesn\'t have to. Available for decisions, reviews, and rapid-fire questions without spinning up a full engagement.',
  },
  {
    no: '06',
    title: 'Team rollout',
    desc: 'Role-specific configs, walkthroughs, and a written playbook. The point is the team is using it in month three — not just month one.',
  },
];

const tools = [
  { slug: 'claude-code-setup', name: 'Claude Code', tag: 'Anthropic · terminal-native dev agent' },
  { slug: 'openclaw-setup',    name: 'OpenClaw',    tag: 'open-source coding agent' },
  { slug: 'codex-setup',       name: 'Codex',       tag: 'OpenAI · coding agent' },
  { slug: 'cursor-setup',      name: 'Cursor',      tag: 'AI-first IDE' },
  { slug: 'cline-setup',       name: 'Cline',       tag: 'VS Code agent extension' },
  { slug: 'aider-setup',       name: 'Aider',       tag: 'terminal pair programmer' },
  { slug: 'hermes-agent-setup',name: 'Hermes',      tag: 'autonomous task agent' },
];

const steps = [
  {
    no: '01',
    title: 'Talk to the duck',
    detail: 'Free 5-minute conversation. Walk me through where your team is today and what\'s slowing you down. No deck, no funnel.',
  },
  {
    no: '02',
    title: 'Get a scoping brief',
    detail: 'I send a one-page brief: what the retainer covers, which problems we tackle first, what\'s out of scope. Sign or pass.',
  },
  {
    no: '03',
    title: 'I keep up. You ship.',
    detail: 'On retainer, I track the firehose and filter it to what matters for your specific context. You get clear decisions, not a list of things to evaluate.',
  },
];
---

<BaseLayout title={title} description={description} schema={websiteSchema}>
  {/* === HERO (DARK) === */}
  <section class="section-dark relative overflow-hidden">
    <div
      class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full pointer-events-none opacity-[0.08]"
      style="background: radial-gradient(circle, #FFC83D 0%, transparent 65%);"
      aria-hidden="true"
    />

    <div class="container-x pt-24 lg:pt-36 pb-20 lg:pb-28 relative">
      <div class="status-pill mb-7 lg:mb-8">
        <span class="status-pill__dot"></span>
        <span>// AI consultant &amp; developer</span>
      </div>

      <h1 class="display-h1 max-w-[24ch] mb-6 lg:mb-8">
        I build the software,<br/>
        <span class="accent-saffron">and the AI inside it.</span><span class="cursor"></span>
      </h1>

      <div class="space-y-5 text-[18px] lg:text-[20px] text-bone-dim leading-[1.55] max-w-[62ch] mb-10">
        <p>
          An AI-focused developer and consultant for growing companies. I build and maintain
          custom software and websites, wire AI into how your team already works, and train
          your people to actually use it &mdash; engineers and creative teams alike &mdash; as
          a one-off project or an ongoing retainer.
        </p>
        <p>
          I work like a forward-deployed engineer: I scope it, build it, and I'm the one who
          answers when it breaks at 2am. One senior person, accountable end to end &mdash; no
          junior bench, no handoff.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <a class="btn btn-primary" href="/talk/">
          Talk to the duck →
        </a>
        <a class="btn btn-outline-light" href="#shapes">
          See what I take on
        </a>
      </div>
    </div>
  </section>

  {/* === THREE BUYER-SEGMENT SHAPES (DARK) === */}
  <Section tone="dark" label="Who this is for" id="shapes">
    <div class="grid grid-cols-12 gap-x-6 gap-y-8">
      <div class="col-span-12 lg:col-span-5">
        <h2 class="display-h2 mb-5">
          Does this<br/>
          <span class="accent-saffron">sound familiar?</span>
        </h2>
        <p class="text-[16px] text-bone-dim leading-[1.65] max-w-[44ch]">
          Growing companies that need something built, integrated, or owned — with AI where it helps.
          If none of these fit cleanly, <a href="/talk/" class="link-saffron">talk to the duck</a> and it'll route you.
        </p>
      </div>
      <div class="col-span-12 lg:col-span-7 grid grid-cols-1 gap-4">
        {shapes.map((c) => (
          <a
            href={c.href}
            class="card-dark p-6 lg:p-7 hover:-translate-y-0.5 hover:border-saffron/40 transition-all group block"
          >
            <div class="font-mono text-[10px] tracking-spec uppercase text-saffron-shadow mb-3">{c.tag}</div>
            <h3 class="text-[22px] lg:text-[24px] font-semibold tracking-tight2 text-bone mb-3 group-hover:text-saffron transition-colors">{c.head}</h3>
            <p class="text-[15px] text-bone-dim leading-[1.65]">{c.body}</p>
            <div class="mt-4 font-mono text-[11px] tracking-spec uppercase text-bone-mute group-hover:text-saffron transition-colors">
              Talk to the duck →
            </div>
          </a>
        ))}
      </div>
    </div>
  </Section>

  {/* === WHAT THE RETAINER COVERS (CREAM) === */}
  <Section tone="cream" label="What the retainer covers" id="what">
    <div class="grid grid-cols-12 gap-x-6 gap-y-8">
      <div class="col-span-12 lg:col-span-5">
        <h2 class="display-h2 mb-5">
          One person.<br/>
          <span class="accent-saffron">The whole picture.</span>
        </h2>
        <p class="text-[17px] text-coal-dim leading-[1.65] mb-3 max-w-[44ch]">
          A fractional AI lead isn't a consultant who shows up with a deck. It's an ongoing
          relationship — someone who knows your stack, tracks the field, and tells you
          what to do next.
        </p>
        <p class="text-[15px] text-coal-mute leading-[1.65] max-w-[44ch]">
          Not sure what you actually need? <a href="/talk/" class="link-coal">Talk to the duck</a>
          &nbsp;and I'll tell you the right scope.
        </p>
      </div>

      <div class="col-span-12 lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-4">
        {capabilities.map((c) => (
          <div class="card-cream p-6">
            <div class="font-mono text-[11px] tracking-spec uppercase text-coal-mute mb-3">{c.no}</div>
            <h3 class="text-[20px] font-semibold tracking-tight2 text-coal mb-3">{c.title}</h3>
            <p class="text-[14px] text-coal-dim leading-[1.6]" set:html={c.desc} />
          </div>
        ))}
      </div>
    </div>
  </Section>

  {/* === THE STACK I ACTUALLY WORK ACROSS (DARK) === */}
  <Section tone="dark" label="// the stack I actually work across" id="tools">
    <div class="grid grid-cols-12 gap-x-6 gap-y-8 items-end mb-10">
      <div class="col-span-12 lg:col-span-7">
        <h2 class="display-h2">
          Not every tool.<br/>
          <span class="accent-saffron">The ones that ship.</span>
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-5 text-[15px] text-bone-dim lg:text-right">
        I work across agents, IDEs, and coding tools daily — so I know which ones are
        production-ready<br class="hidden lg:block"/> and which are still demo ware.
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map((t) => (
        <a
          href={`/solutions/${t.slug}/`}
          class="card-dark p-5 lg:p-6 hover:-translate-y-0.5 hover:border-saffron/40 transition-all group block"
        >
          <div class="flex items-baseline justify-between mb-2">
            <h3 class="text-[20px] font-semibold tracking-tight2 text-bone group-hover:text-saffron transition-colors">{t.name}</h3>
            <span class="font-mono text-[10px] tracking-spec uppercase text-bone-mute group-hover:text-saffron transition-colors">→</span>
          </div>
          <div class="text-[13px] text-bone-dim leading-[1.55]">{t.tag}</div>
        </a>
      ))}
    </div>
  </Section>

  {/* === HOW IT WORKS (CREAM) === */}
  <Section tone="cream" label="How it works" id="how">
    <div class="grid grid-cols-12 gap-x-8 gap-y-10">
      <div class="col-span-12 lg:col-span-5">
        <h2 class="display-h2 mb-5">
          From <span class="accent-saffron">talk</span> to<br/>
          <span class="accent-saffron">on retainer</span> in three steps.
        </h2>
        <p class="text-[17px] text-coal-dim leading-[1.65] mb-6 max-w-[44ch]">
          Solo. No agency layers, no AE handoffs. The person you talk to first
          is the person on retainer &mdash; one relationship, not a rotating cast.
        </p>
        <a href="/talk/" class="btn btn-primary">Talk to the duck →</a>
      </div>

      <ol class="col-span-12 lg:col-span-7 grid grid-cols-1 gap-4">
        {steps.map((s) => (
          <li class="card-cream p-6 lg:p-7">
            <div class="flex items-baseline gap-3 mb-3">
              <span class="font-mono text-[11px] tracking-spec uppercase text-coal-mute">Step</span>
              <span class="font-mono text-[28px] tracking-tight2 text-saffron-shadow leading-none tabular">{s.no}</span>
            </div>
            <h3 class="text-[22px] font-semibold tracking-tight2 text-coal mb-2">{s.title}</h3>
            <p class="text-[15px] text-coal-dim leading-[1.65]">{s.detail}</p>
          </li>
        ))}
      </ol>
    </div>
  </Section>

  {/* === FINAL CTA (DARK) === */}
  <Section tone="dark">
    <div class="grid grid-cols-12 gap-x-8 gap-y-8 items-center">
      <div class="col-span-12 lg:col-span-8">
        <div class="label mb-5">Next move</div>
        <h2 class="display-h2 mb-5">
          Stop fielding every<br/>
          <span class="accent-saffron">AI question yourself.</span>
        </h2>
        <p class="text-[17px] text-bone-dim leading-[1.6] max-w-[58ch] mb-8">
          Free 5-minute conversation. Tell the duck what your team is dealing with today
          and you'll leave with a one-page scoping brief and a clear shape for what a
          retainer looks like.
        </p>
        <div class="flex flex-col sm:flex-row flex-wrap gap-3">
          <a href="/talk/" class="btn btn-primary">Talk to the duck →</a>
          <a href="/about/" class="btn btn-outline-light">About Long</a>
        </div>
      </div>
      <div class="col-span-12 lg:col-span-4 hidden lg:flex justify-end">
        <img src="/logo-rdts-light.webp" alt="Rubber Duck Tech Solutions" width="240" height="240" loading="lazy" class="w-[240px] h-[240px] object-contain" />
      </div>
    </div>
  </Section>
</BaseLayout>
