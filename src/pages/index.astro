---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const title = 'RDTS — I install your AI environment';
const description = 'Your team pays for ChatGPT or Claude and barely uses it. I install your AI environment — skills, agents, integrations, the whole stack — so it actually works for the way your team operates.';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Rubber Duck Tech Solutions',
  url: 'https://www.rubberducktechsolutions.com/',
  description,
};

const shapes = [
  {
    tag: '01 · solo / indie dev',
    head: 'You\'re the whole team.',
    body: 'You pay for Claude or ChatGPT, use 10% of it, and don\'t have time to figure out the rest. I tune your environment — skills, shortcuts, agents wired to your stack — so the tools start pulling weight in your actual workflow.',
    href: '/talk/',
  },
  {
    tag: '02 · small team · 1–6',
    head: 'Your team uses AI five different ways.',
    body: 'Everyone has their own prompts, their own habits, their own blind spots. I install a shared AI environment — same skills, same agents, same knowledge layer — so the team works off one stack instead of five.',
    href: '/talk/',
  },
  {
    tag: '03 · agency · 5–20',
    head: 'You bought seats; nobody knows what\'s possible.',
    body: 'AI is in the stack but adoption is uneven and the wins are accidental. I roll out a real environment across the team — role-specific configs, agents for the repeated work, training so it sticks past week one.',
    href: '/talk/',
  },
];

const capabilities = [
  {
    no: '01',
    title: 'Skills',
    desc: 'Reusable instructions and workflows the model actually follows. Vetted public skills plus custom skills tuned to your team\'s work.',
  },
  {
    no: '02',
    title: 'Agents',
    desc: 'Long-running, tool-using agents that own the repeated work — research, content drafts, code review, ops triage. Scoped to what your team actually does.',
  },
  {
    no: '03',
    title: 'Integrations',
    desc: 'MCP servers and direct API wiring into the systems you already pay for — CRM, CMS, analytics, support, repos, drives.',
  },
  {
    no: '04',
    title: 'Knowledge layer',
    desc: 'Your docs, your style guides, your past work — indexed and retrievable so the model answers in your voice, not the generic one.',
  },
  {
    no: '05',
    title: 'Role configs',
    desc: 'Different setups for engineers, marketers, support, ops. Each role gets the skills, agents, and context that match their work — not one bloated profile for everyone.',
  },
  {
    no: '06',
    title: 'Adoption',
    desc: 'Walkthroughs, recorded training, and a written playbook so the environment outlives the install. The point is the team uses it in week six, not just week one.',
  },
];

const tools = [
  { slug: 'claude-code-setup', name: 'Claude Code', tag: 'Anthropic · terminal-native dev agent' },
  { slug: 'openclaw-setup',    name: 'OpenClaw',    tag: 'open-source coding agent' },
  { slug: 'codex-setup',       name: 'Codex',       tag: 'OpenAI · coding agent' },
  { slug: 'cursor-setup',      name: 'Cursor',      tag: 'AI-first IDE' },
  { slug: 'cline-setup',       name: 'Cline',       tag: 'VS Code agent extension' },
  { slug: 'aider-setup',       name: 'Aider',       tag: 'terminal pair programmer' },
  { slug: 'hermes-agent-setup',name: 'Hermes',      tag: 'autonomous task agent' },
];

const steps = [
  {
    no: '01',
    title: 'Talk to the duck',
    detail: 'Free 5-minute conversation. Walk me through what your team uses today and where it\'s falling short. No deck, no funnel.',
  },
  {
    no: '02',
    title: 'Get a scoping brief',
    detail: 'I send a one-page brief: what gets installed, which tools, which roles, fixed timeline, what\'s out of scope. Sign or pass.',
  },
  {
    no: '03',
    title: 'Long ships it',
    detail: 'Solo install. Skills built, agents wired, integrations live, team trained. One week for a tuneup, up to six weeks for a full agency rollout.',
  },
];
---

<BaseLayout title={title} description={description} schema={websiteSchema}>
  {/* === HERO (DARK) === */}
  <section class="section-dark relative overflow-hidden">
    <div
      class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full pointer-events-none opacity-[0.08]"
      style="background: radial-gradient(circle, #FFC83D 0%, transparent 65%);"
      aria-hidden="true"
    />

    <div class="container-x pt-24 lg:pt-36 pb-20 lg:pb-28 relative">
      <div class="status-pill mb-7 lg:mb-8">
        <span class="status-pill__dot"></span>
        <span>Available · 1 of 2 slots · 2026 Q2</span>
      </div>

      <h1 class="display-h1 max-w-[22ch] mb-6 lg:mb-8">
        Your team's AI is<br/>
        <span class="accent-saffron">set up wrong.</span><span class="cursor"></span>
      </h1>

      <div class="space-y-5 text-[18px] lg:text-[20px] text-bone-dim leading-[1.55] max-w-[62ch] mb-10">
        <p>
          Most teams pay for ChatGPT Teams or Claude and barely use it. The tools don't know your work,
          the team uses them differently, and nobody knows what's possible.
        </p>
        <p>
          I install your AI environment &mdash; skills, agents, integrations, the whole stack &mdash;
          so it actually works for the way your team operates.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <a class="btn btn-primary" href="/talk/">
          Talk to the duck →
        </a>
        <a class="btn btn-outline-light" href="#shapes">
          See the shapes
        </a>
      </div>
    </div>
  </section>

  {/* === THREE BUYER-SEGMENT SHAPES (DARK) === */}
  <Section tone="dark" label="Three shapes" id="shapes">
    <div class="grid grid-cols-12 gap-x-6 gap-y-8">
      <div class="col-span-12 lg:col-span-5">
        <h2 class="display-h2 mb-5">
          Pick the shape<br/>
          that <span class="accent-saffron">sounds like you</span>.
        </h2>
        <p class="text-[16px] text-bone-dim leading-[1.65] max-w-[44ch]">
          Three buyer shapes, three different installs. If none of them fit cleanly,
          <a href="/talk/" class="link-saffron">talk to the duck</a> and it'll route you.
        </p>
      </div>
      <div class="col-span-12 lg:col-span-7 grid grid-cols-1 gap-4">
        {shapes.map((c) => (
          <a
            href={c.href}
            class="card-dark p-6 lg:p-7 hover:-translate-y-0.5 hover:border-saffron/40 transition-all group block"
          >
            <div class="font-mono text-[10px] tracking-spec uppercase text-saffron-shadow mb-3">{c.tag}</div>
            <h3 class="text-[22px] lg:text-[24px] font-semibold tracking-tight2 text-bone mb-3 group-hover:text-saffron transition-colors">{c.head}</h3>
            <p class="text-[15px] text-bone-dim leading-[1.65]">{c.body}</p>
            <div class="mt-4 font-mono text-[11px] tracking-spec uppercase text-bone-mute group-hover:text-saffron transition-colors">
              Talk to the duck →
            </div>
          </a>
        ))}
      </div>
    </div>
  </Section>

  {/* === WHAT I ACTUALLY SET UP (CREAM) === */}
  <Section tone="cream" label="What I actually set up" id="what">
    <div class="grid grid-cols-12 gap-x-6 gap-y-8">
      <div class="col-span-12 lg:col-span-5">
        <h2 class="display-h2 mb-5">
          The install,<br/>
          <span class="accent-saffron">end to end</span>.
        </h2>
        <p class="text-[17px] text-coal-dim leading-[1.65] mb-3 max-w-[44ch]">
          AI environments aren't one thing. They're six things stacked together &mdash;
          and they only work when all six are set up for your team specifically.
        </p>
        <p class="text-[15px] text-coal-mute leading-[1.65] max-w-[44ch]">
          Not sure which pieces you need? <a href="/talk/" class="link-coal">Talk to the duck</a>
          &nbsp;and I'll tell you the right move.
        </p>
      </div>

      <div class="col-span-12 lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-4">
        {capabilities.map((c) => (
          <div class="card-cream p-6">
            <div class="font-mono text-[11px] tracking-spec uppercase text-coal-mute mb-3">{c.no}</div>
            <h3 class="text-[20px] font-semibold tracking-tight2 text-coal mb-3">{c.title}</h3>
            <p class="text-[14px] text-coal-dim leading-[1.6]">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  {/* === TOOLS I WORK WITH (DARK) === */}
  <Section tone="dark" label="Tools I work with" id="tools">
    <div class="grid grid-cols-12 gap-x-6 gap-y-8 items-end mb-10">
      <div class="col-span-12 lg:col-span-7">
        <h2 class="display-h2">
          Seven tools I install,<br/>
          <span class="accent-saffron">tune, and train teams on</span>.
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-5 text-[15px] text-bone-dim lg:text-right">
        Use the one that fits your team. Or talk to the duck<br class="hidden lg:block"/>
        and it'll tell you which one matches your stack.
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map((t) => (
        <a
          href={`/solutions/${t.slug}/`}
          class="card-dark p-5 lg:p-6 hover:-translate-y-0.5 hover:border-saffron/40 transition-all group block"
        >
          <div class="flex items-baseline justify-between mb-2">
            <h3 class="text-[20px] font-semibold tracking-tight2 text-bone group-hover:text-saffron transition-colors">{t.name}</h3>
            <span class="font-mono text-[10px] tracking-spec uppercase text-bone-mute group-hover:text-saffron transition-colors">→</span>
          </div>
          <div class="text-[13px] text-bone-dim leading-[1.55]">{t.tag}</div>
        </a>
      ))}
    </div>
  </Section>

  {/* === HOW IT WORKS (CREAM) === */}
  <Section tone="cream" label="How it works" id="how">
    <div class="grid grid-cols-12 gap-x-8 gap-y-10">
      <div class="col-span-12 lg:col-span-5">
        <h2 class="display-h2 mb-5">
          From <span class="accent-saffron">talk</span> to<br/>
          <span class="accent-saffron">installed</span> in three steps.
        </h2>
        <p class="text-[17px] text-coal-dim leading-[1.65] mb-6 max-w-[44ch]">
          Solo studio. No agency layers, no AE handoffs. The person you talk to first
          is the person installing your environment &mdash; that's the entire point.
        </p>
        <a href="/talk/" class="btn btn-primary">Talk to the duck →</a>
      </div>

      <ol class="col-span-12 lg:col-span-7 grid grid-cols-1 gap-4">
        {steps.map((s) => (
          <li class="card-cream p-6 lg:p-7">
            <div class="flex items-baseline gap-3 mb-3">
              <span class="font-mono text-[11px] tracking-spec uppercase text-coal-mute">Step</span>
              <span class="font-mono text-[28px] tracking-tight2 text-saffron-shadow leading-none tabular">{s.no}</span>
            </div>
            <h3 class="text-[22px] font-semibold tracking-tight2 text-coal mb-2">{s.title}</h3>
            <p class="text-[15px] text-coal-dim leading-[1.65]">{s.detail}</p>
          </li>
        ))}
      </ol>
    </div>
  </Section>

  {/* === FINAL CTA (DARK) === */}
  <Section tone="dark">
    <div class="grid grid-cols-12 gap-x-8 gap-y-8 items-center">
      <div class="col-span-12 lg:col-span-8">
        <div class="label mb-5">Next move</div>
        <h2 class="display-h2 mb-5">
          Your AI stack should<br/>
          <span class="accent-saffron">earn its seat.</span>
        </h2>
        <p class="text-[17px] text-bone-dim leading-[1.6] max-w-[58ch] mb-8">
          Free 5-minute conversation. Tell the duck how your team works today and you'll leave
          with a one-page scoping brief, a fixed timeline, and a clear shape.
        </p>
        <div class="flex flex-col sm:flex-row flex-wrap gap-3">
          <a href="/talk/" class="btn btn-primary">Talk to the duck →</a>
          <a href="/about/" class="btn btn-outline-light">About Long</a>
        </div>
      </div>
      <div class="col-span-12 lg:col-span-4 hidden lg:flex justify-end">
        <img src="/logo-rdts-light.webp" alt="Rubber Duck Tech Solutions" width="240" height="240" loading="lazy" class="w-[240px] h-[240px] object-contain" />
      </div>
    </div>
  </Section>
</BaseLayout>
