---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const title = 'Pricing — fixed tiers for custom AI software | RDTS';
const description = 'Transparent pricing: $1,500 starter tool, $3,500 full pipeline, custom retainer. No marketplace bidding, no agency markup, no surprises.';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Custom AI software development',
  description: 'Fixed-price custom AI software development for content teams. Tiers from $1,500 to custom monthly retainers.',
  provider: { '@type': 'Organization', name: 'Rubber Duck Tech Solutions' },
  areaServed: { '@type': 'Country', name: 'US' },
  offers: [
    {
      '@type': 'Offer',
      name: 'Tier A1 — Starter Tool',
      priceCurrency: 'USD',
      price: '1500',
      description: 'One sharp AI tool. ~1 week build.',
    },
    {
      '@type': 'Offer',
      name: 'Tier S3 — Full Pipeline',
      priceCurrency: 'USD',
      price: '3500',
      description: 'Multi-step AI pipeline with admin UI. 2–4 week build.',
    },
    {
      '@type': 'Offer',
      name: 'Custom — Ongoing Build',
      priceCurrency: 'USD',
      description: 'Monthly retainer for custom internal products. Scoped per project.',
    },
  ],
};

const tiers = [
  {
    no: 'A1',
    name: 'Starter Tool',
    price: '$1,500',
    timeline: '~1 week',
    summary: 'One sharp tool with one input and one output. The thing your team currently does in 15 manual steps.',
    examples: [
      'AI transcript cleaner — raw video → shippable posts',
      'Content idea pipeline — brief → 20 ranked angles',
      'Repurposer — podcast → 3 platform-specific cuts',
      'Internal AI assistant scoped to your data',
    ],
    includes: [
      'Single AI tool, deployed to your hosting',
      'Source code transfers to you on delivery',
      'Choice of Claude, OpenAI, or multi-model',
      '7 days of post-ship bug fixes',
      'A README that’s actually useful',
    ],
    notIncluded: [
      'Multi-step branching workflows (→ Tier S3)',
      'Multi-user dashboard (→ Tier S3)',
      'Ongoing iteration (→ Custom)',
    ],
    cta: 'Tier A1 — start',
  },
  {
    no: 'S3',
    name: 'Full Solution',
    price: '$3,500',
    timeline: '2–4 weeks',
    summary: 'A real multi-step AI pipeline with admin UI, integrations, and the bits Zapier and n8n can’t do.',
    examples: [
      'Agency-side content automation across 8–10 clients',
      'AI-powered internal dashboard with custom logic',
      'Zapier/n8n migration to real code (~5–10 flows)',
      'AI agent with tool use, branching, multi-step logic',
    ],
    includes: [
      'Multi-step pipeline + admin/queue UI',
      'Database (Postgres or Supabase) — your data, your account',
      'Multi-model AI routing if needed',
      'CI/CD set up on your hosting',
      '30 days of post-ship support',
      'Source code + transfer doc',
    ],
    notIncluded: [
      'Multi-tenant SaaS architecture (→ Custom)',
      'Mobile apps (→ Custom)',
      'Ongoing feature work past 30 days (→ Custom retainer)',
    ],
    cta: 'Tier S3 — start',
    recommended: true,
  },
  {
    no: 'C-X',
    name: 'Custom Build',
    price: 'scoped',
    timeline: 'monthly',
    summary: 'Your own internal product. Multi-user, billing, complex AI orchestration, ongoing iteration.',
    examples: [
      'Multi-tenant SaaS for your agency clients',
      'Internal AI product across multiple teams',
      'Long-running build (3+ months) with weekly check-ins',
      'Anything that doesn’t fit cleanly into A1 or S3',
    ],
    includes: [
      'Custom roadmap shaped together',
      'Weekly demos + planning sync',
      'Source code in your repo from day 1',
      'Ongoing iteration past initial scope',
      'Priority email + Slack channel',
    ],
    notIncluded: [
      'Anything I’m not the right person for — I’ll tell you straight',
    ],
    cta: 'Talk first',
  },
];

const faqs = [
  {
    q: 'Why fixed pricing instead of hourly?',
    a: 'Hourly billing rewards me for being slow and punishes you for asking questions. Fixed pricing keeps incentives aligned: I get paid for the outcome, not the clock. If I underestimate, that’s on me. If you change scope, we re-scope honestly. The only exceptions are Custom retainers (monthly) where the work is genuinely open-ended.',
  },
  {
    q: 'What’s included beyond the build?',
    a: 'Tier A1 includes 7 days of post-ship bug fixes. Tier S3 includes 30 days. Both include source code transfer (it’s yours, not mine), a deployment doc, and a README that explains the system to a future developer. Custom retainers include ongoing work and priority Slack access.',
  },
  {
    q: 'How do payments work?',
    a: 'For A1 and S3: 50% deposit to start, 50% on delivery. ACH or Stripe. For Custom retainers: monthly invoicing in advance. I’m a US-registered LLC (Long Win LLC) so 1099 / W9 work is straightforward for US clients.',
  },
  {
    q: 'What if my project doesn’t fit your tiers?',
    a: 'Then we have a 5-minute call and either I’ll show you a fair Custom scope, or I’ll honestly tell you it’s not the right fit. I refer out work I’m not the best person for. The worst outcome is a free conversation.',
  },
  {
    q: 'Do you take equity, sweat-only, or revenue share?',
    a: 'No. Cash only. I’ve seen too many "we’ll pay in equity" deals end with the founder ghosting after delivery. RDTS is a working studio, not a co-founder hunt.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} schema={[serviceSchema, faqSchema]}>
  {/* HERO */}
  <section class="section-dark">
    <div class="container-x pt-20 lg:pt-28 pb-12 lg:pb-16">
      <div class="status-pill mb-6"><span class="status-pill__dot"></span><span>Available · 1 of 2 slots · 2026 Q2</span></div>
      <h1 class="display-h1 max-w-[20ch] mb-6">
        Three tiers, real numbers,<br/>
        no <span class="accent-saffron">"contact us"</span><span class="cursor"></span>
      </h1>
      <p class="text-[18px] text-bone-dim leading-[1.6] max-w-[58ch]">
        Pricing is a feature. You should know what something costs before you book a call. The
        three tiers below cover ~90% of work I do for content teams; if your project doesn't fit,
        we'll scope a fair Custom plan together.
      </p>
    </div>
  </section>

  {/* TIERS */}
  <Section tone="cream" label="Tiers">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-6">
      {tiers.map((t) => (
        <div class:list={[
          'card-cream p-6 lg:p-8 relative flex flex-col',
          t.recommended && 'ring-2 ring-saffron',
        ]}>
          {t.recommended && (
            <div class="absolute -top-3 left-6 bg-saffron text-coal text-[10px] font-mono tracking-spec uppercase font-medium px-3 py-1 rounded-pill">
              Most common
            </div>
          )}
          <div class="flex items-baseline justify-between mb-2">
            <span class="font-mono text-[11px] tracking-spec uppercase text-coal-mute">Tier {t.no}</span>
            <span class="font-mono text-[11px] tracking-spec uppercase text-coal-mute">{t.timeline}</span>
          </div>
          <h2 class="text-[26px] lg:text-[28px] font-semibold tracking-tight2 text-coal mb-1">{t.name}</h2>
          <div class="text-[36px] lg:text-[40px] font-bold text-coal tracking-tight3 mb-4 tabular">
            {t.price}
          </div>
          <p class="text-[15px] text-coal-dim leading-[1.6] mb-6">{t.summary}</p>

          <div class="mb-5">
            <div class="label label--coal mb-3">Examples</div>
            <ul class="space-y-1.5 text-[14px] text-coal-dim">
              {t.examples.map((e) => <li>· {e}</li>)}
            </ul>
          </div>

          <div class="mb-5">
            <div class="label label--coal mb-3">Includes</div>
            <ul class="space-y-1.5 text-[14px] text-coal-dim">
              {t.includes.map((e) => <li class="flex gap-2"><span class="text-saffron-shadow">✓</span><span>{e}</span></li>)}
            </ul>
          </div>

          <div class="mb-7">
            <div class="label label--coal mb-3">Not included</div>
            <ul class="space-y-1.5 text-[14px] text-coal-mute">
              {t.notIncluded.map((e) => <li>· {e}</li>)}
            </ul>
          </div>

          <a href="/talk" class:list={['btn mt-auto', t.recommended ? 'btn-primary' : 'btn-outline-dark']}>{t.cta}</a>
        </div>
      ))}
    </div>
  </Section>

  {/* ALSO AVAILABLE — special offerings that don't fit cleanly into A1/S3/CX */}
  <Section tone="dark" label="Also available">
    <div class="grid grid-cols-12 gap-x-8 gap-y-8">
      <div class="col-span-12 lg:col-span-5">
        <h2 class="display-h2 mb-5">
          Two specialized<br/>
          <span class="accent-saffron">workflow</span> offerings.
        </h2>
        <p class="text-[16px] text-bone-dim leading-[1.65] max-w-[44ch]">
          These don't slot cleanly into A1/S3/CX. Pricing scoped per engagement —
          <a href="/talk" class="link-saffron">talk to the duck</a> for a quote.
        </p>
      </div>
      <div class="col-span-12 lg:col-span-7 grid grid-cols-1 gap-4">
        {[
          {
            tag: 'Ongoing · usually retainer',
            head: 'Ad iteration loop',
            body: 'Take a creative that already converts. The loop I build generates dozens of on-brand variations nightly — copy, captions, thumbnail tweaks, A/B-ready exports. You wake up to a fresh batch.',
            inputs: 'Your winning ad + brand voice doc',
            outputs: 'Daily batches of testable variants',
          },
          {
            tag: 'One-time · ~1–2 weeks',
            head: 'Claude Code rollout for your team',
            body: 'Set your team up with the same Claude Code workflow I use every day: vetted skills installed, custom skills built for your workflows, MCP servers wired to your CMS / CRM / analytics stack. Training session included.',
            inputs: 'Your stack + team workflows',
            outputs: 'Skilled Claude Code, custom skills, training video',
          },
        ].map((s) => (
          <div class="card-dark p-6 lg:p-7">
            <div class="font-mono text-[10px] tracking-spec uppercase text-saffron-shadow mb-3">{s.tag}</div>
            <h3 class="text-[22px] lg:text-[24px] font-semibold tracking-tight2 text-bone mb-3">{s.head}</h3>
            <p class="text-[15px] text-bone-dim leading-[1.65] mb-4">{s.body}</p>
            <div class="grid grid-cols-2 gap-4 pt-4 border-t border-ink-border text-[13px]">
              <div>
                <div class="font-mono text-[10px] tracking-spec uppercase text-bone-mute mb-1">In</div>
                <div class="text-bone-dim">{s.inputs}</div>
              </div>
              <div>
                <div class="font-mono text-[10px] tracking-spec uppercase text-bone-mute mb-1">Out</div>
                <div class="text-bone-dim">{s.outputs}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>

  {/* WHAT'S NOT ON HERE */}
  <Section tone="cream" label="What I don't do">
    <div class="grid grid-cols-12 gap-x-8 gap-y-8">
      <div class="col-span-12 lg:col-span-5">
        <h2 class="display-h2 mb-5">Honest <span class="accent-saffron">no</span> list.</h2>
        <p class="text-[16px] text-coal-dim leading-[1.65] max-w-[44ch]">
          I'd rather refer you to someone better than take a job I'm wrong for. These are
          things RDTS isn't the right shop for. <a href="/talk" class="link-coal">Talk to the duck</a>
          and I'll send you to who is.
        </p>
      </div>
      <ul class="col-span-12 lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          ['Pure marketing sites','Get a Webflow studio. RDTS is for software, not landing pages.'],
          ['Training models from weights','LoRA, SFT, RLHF — different specialty. I integrate models, I don’t train new ones. I’ll refer you.'],
          ['Mobile apps','React Native specialists exist. I’m not one.'],
          ['Crypto / token / web3','Not building in this space.'],
          ['"Equity-only" deals','Cash only. See FAQ.'],
        ].map(([head, body]) => (
          <li class="card-cream p-5">
            <div class="text-coal font-semibold text-[15px] mb-1.5">{head}</div>
            <div class="text-coal-dim text-[14px] leading-[1.6]">{body}</div>
          </li>
        ))}
      </ul>
    </div>
  </Section>

  {/* FAQ */}
  <Section tone="cream" label="FAQ">
    <div class="grid grid-cols-12 gap-x-8 gap-y-8">
      <div class="col-span-12 lg:col-span-4">
        <h2 class="display-h2 mb-4">Pricing<br/>questions.</h2>
        <p class="text-[15px] text-coal-dim leading-[1.6]">
          Anything else? <a href="/talk" class="link-coal">Ask the duck</a>.
        </p>
      </div>
      <div class="col-span-12 lg:col-span-8 space-y-4">
        {faqs.map((f) => (
          <details class="card-cream p-6 lg:p-7 group">
            <summary class="cursor-pointer flex items-start justify-between gap-4 list-none">
              <h3 class="text-[18px] font-semibold tracking-tight2 text-coal pr-4">{f.q}</h3>
              <span class="text-saffron-shadow text-[24px] leading-none shrink-0 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="text-[15px] text-coal-dim leading-[1.7] mt-4">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </Section>

  {/* CTA */}
  <Section tone="dark">
    <div class="text-center max-w-[640px] mx-auto">
      <div class="label justify-center mb-5">Next move</div>
      <h2 class="display-h2 mb-5">Pick a tier or talk it through.</h2>
      <p class="text-[16px] text-bone-dim leading-[1.65] mb-8">
        Free 5-minute call. No deck, no funnel. Tell me what you're building and you'll leave with a
        scoped tier, a fixed price, and a timeline.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/talk" class="btn btn-primary">Talk to the duck</a>
        <a href="/contact" class="btn btn-outline-light">Email instead</a>
      </div>
    </div>
  </Section>
</BaseLayout>
