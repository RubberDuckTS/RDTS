---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';

const title = 'Hire an AI developer who actually ships | Long Nguyen / RDTS';
const description = 'AI developer for hire — I install your AI environment (skills, agents, MCP servers, harnesses) and build custom software when you need the app, not the stack. Source code yours, solo engineer in MO.';

const canonical = '/services/ai-developer-for-hire/';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Hire an AI developer who actually ships',
  description,
  author: {
    '@type': 'Person',
    name: 'Long Nguyen',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Rubber Duck Tech Solutions',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://www.rubberducktechsolutions.com/services/ai-developer-for-hire/',
  },
  datePublished: '2026-05-05',
  dateModified: '2026-05-21',
};

const faqs = [
  {
    q: 'How experienced are you as an AI developer for hire?',
    a: 'Nearly a decade writing production software, since 2018 — back when LLMs could not yet ship usable code. Spent the agency years as the in-house dev other teams called when their tools stopped fitting their work. Since going solo as RDTS I have shipped real production AI software — including ClipMango, a multi-model AI music video pipeline, and a creator booking platform with AI-assisted matching. I work full time on Anthropic Claude (frontier and small variants), OpenAI GPT models, MCP servers, Claude skills, and the harnesses people actually use day-to-day: Claude Code, Cursor, Codex, OpenClaw, Cline, Aider. No bench, no offshore handoff — you talk to the engineer doing the work.',
  },
  {
    q: 'What is your availability and turnaround time?',
    a: 'I typically start new engagements within one to two weeks of the scoping conversation. One-day micro-jobs (single skill install, one MCP wiring, page-speed fix) start at $500 and ship in days. Tuneup-shaped work for one person ships in about a week. Team Workspace setups ship in one to two weeks. Larger Rollouts (agency, role-specific configs, adoption work) run three to six weeks. I run one to two engagements at a time so deadlines are real, not aspirational. If I cannot start in your window I will say so on the scoping call.',
  },
  {
    q: 'Will you sign an NDA?',
    a: 'Yes. I sign mutual NDAs before any scoping conversation that touches sensitive data, prompts, customer lists, or proprietary workflows. If you have a standard NDA on hand, send it. If not, I have a short one that works for most engagements.',
  },
  {
    q: 'Do I own the source code and the IP?',
    a: 'Yes. Every engagement transfers full source code, configs, and IP rights to you on final payment. You get the GitHub repo, the deploy keys, the prompt files, the skill definitions, the MCP server source — everything. No platform lock-in, no licensed black box, no per-seat fee on top. If you want to fire me and hand the codebase to another engineer next quarter, the codebase is structured so that works.',
  },
  {
    q: 'Do you offer ongoing support after launch?',
    a: 'Yes, optionally. After ship I include a short bug-fix window at no charge. Beyond that I offer a monthly retainer for ongoing skill iteration, model upgrades, integration work, and additional builds — scoped per client. Some clients want one setup and disappear. Some keep me on for new skills and new pipelines every month. Both are fine.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'AI Developer for Hire',
  description: 'AI environment setup — skills, agents, MCP servers, harness configuration — plus custom AI software development when the work calls for an app, not a stack.',
  provider: { '@type': 'Organization', name: 'Rubber Duck Tech Solutions' },
  areaServed: { '@type': 'Country', name: 'US' },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'USD',
    priceSpecification: {
      '@type': 'PriceSpecification',
      minPrice: '500',
      priceCurrency: 'USD',
    },
  },
};

const buildCategories = [
  {
    title: 'AI environment setup',
    body: 'The primary lane. I install your harness (Claude Code, Cursor, Codex, OpenClaw, Cline, Aider — whichever fits the work), write the skills that know your codebase and standards, wire up the MCP servers that connect your existing tools, and configure agents that can actually do the work — not just describe it. Set up for the way your team operates, not a generic template off a tutorial.',
  },
  {
    title: 'Custom skills and MCP servers',
    body: 'Claude skills that encode your team\'s playbooks. MCP servers that plug your internal tools, databases, and APIs into Claude Code, Claude Desktop, Cursor, and custom agents. First-class access to your data and actions, no scraping, no brittle browser automation, no credentials leaking into prompts.',
  },
  {
    title: 'Agent harnesses, wired correctly',
    body: 'Most "AI agents" people ask for are really one or two prompted calls with tool use — those do not need a full agent loop. When agents are the right answer, I pick the harness, write the tool surface, set up the retry and guardrail layers, and ship something your team actually runs every day.',
  },
  {
    title: 'Custom AI software',
    body: 'When the duck spots that you need an app, not a setup — I build the app. Full-stack applications where AI is a feature, not the marketing. Next.js or Astro on the front, Node and Postgres or Supabase on the back, model calls wired in where they earn their keep. Auth, billing, file storage, queueing — the boring pieces that turn a demo into software customers pay for.',
  },
  {
    title: 'Internal AI dashboards',
    body: 'Teams hire me to build the dashboard their ops team actually wants — bulk classification, prompt libraries, generation queues, cost tracking, output review. Tailored to your workflow. You stop paying per-seat for a SaaS that does 30% of what you need and start owning the tool that does 100%.',
  },
  {
    title: 'AI integrations into existing software',
    body: 'You already have a CRM, a CMS, a content database, an internal admin panel. I drop AI capabilities into what you already run — semantic search, auto-tagging, draft generation, summarization, translation. Behind your existing auth, in your existing UI, on your existing infra.',
  },
];

const processSteps = [
  {
    label: 'Step 01',
    title: 'Talk to the duck',
    body: 'Five-minute scoping conversation with the duck — a custom AI agent I built. You describe what you\'re trying to set up, who\'s on the team, what\'s broken. The duck reads the shape, names a price in plain English, and sends a brief to both of us. No qualification grid, no funnel, no follow-up sequence.',
  },
  {
    label: 'Step 02',
    title: 'Scope',
    body: 'I send back a one-page scope inside 48 hours: what gets installed or built, what does not, the shape (Quick fix, Tuneup, Workspace, Rollout, or Custom), the timeline, the deliverables, the price. Fixed. If you want changes, we change it before we start, not halfway through. Once you sign, the scope is the contract.',
  },
  {
    label: 'Step 03',
    title: 'Install / build',
    body: 'I do the work solo, in your GitHub org if you have one or a fresh repo I transfer at the end. You see commits as they land. Mid-build check-ins are async — Loom and a shared doc — unless you want a weekly call. No status meetings for the sake of meetings.',
  },
  {
    label: 'Step 04',
    title: 'Ship and hand off',
    body: 'On ship day you get the deploy, the source code, the skill definitions, the MCP server configs, a README another engineer can pick up cold, and a walkthrough recording. A short bug-fix window is included. After that you can take it in-house, hand it to your team, or keep me on monthly retainer for the next round.',
  },
];
---
<BaseLayout title={title} description={description} canonical={canonical} schema={[articleSchema, faqSchema, serviceSchema]}>

  <section class="section-dark">
    <div class="container-x py-20 lg:py-28">
      <div class="status-pill mb-8">
        <span class="status-pill__dot"></span>
        <span>// fractional AI lead</span>
      </div>
      <h1 class="display-h1 mb-8">
        Hire an AI developer<br />who actually <span class="accent-saffron">ships</span><span class="cursor">_</span>
      </h1>
      <p class="text-bone-dim text-lg lg:text-xl max-w-3xl mb-10 leading-relaxed">
        I am Long Nguyen, the engineer behind Rubber Duck Tech Solutions. If you are looking to hire an AI developer for a real production engagement — installing your AI environment (skills, agents, MCP servers, harness configuration), or building the custom software your team needs — this page tells you exactly how I work and why I do not bid on Upwork. Solo engineer, fixed price, source code yours on day one.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/talk/" class="btn btn-primary">Talk to the duck →</a>
      </div>
    </div>
  </section>

  <Section tone="cream" label="Who I am">
    <div class="prose-rdts max-w-3xl">
      <h2 class="display-h2 mb-8">Solo engineer, two agency stints, real projects shipped</h2>
      <p>
        Before RDTS, I spent years as the in-house dev inside two marketing agencies. That is where I learned what teams actually need from software — and how badly most agencies and freelancers miss it. I am not an ex-creator who picked up code last year. I have been writing production software since 2018 — pre-LLM, pre-Midjourney — and I happened to spend a long stretch of that inside content shops.
      </p>
      <p>
        I run RDTS — Rubber Duck Tech Solutions, the trade name of Long Win LLC, registered in Missouri — as a solo practice. No bench, no offshore subcontractors, no project managers in the way. When you hire me, you get me. The engineer on the call is the engineer doing the setup and the engineer responding to bugs at 11pm before launch.
      </p>
      <p>
        My current default kit: Anthropic Claude (the frontier model for reasoning, a smaller Claude variant for high-volume classification), OpenAI's flagship GPT where it specifically wins, MCP servers and the Claude Agent SDK for tool-using agents, custom Claude skills for team standards, harness configuration across Claude Code, Cursor, Codex, OpenClaw, Cline, and Aider, Node and TypeScript on the server, Postgres or Supabase for data, and Astro or Next.js on the front. I built ClipMango — an end-to-end AI music video pipeline that orchestrates lyric segmentation, keyframe generation, and Seedance video models — entirely solo. I shipped Lee De Card, a creator booking platform, and Dragon Wagons, a content automation backend, the same way.
      </p>
      <p>
        If you want <a href="/about/" class="link-coal">more about my background</a>, the about page goes deeper. If you want to skip ahead and talk, <a href="/talk/" class="link-coal">talk to the duck</a>.
      </p>
    </div>
  </Section>

  <Section tone="dark" label="What I build (and ship)">
    <h2 class="display-h2 mb-12">What hiring an AI developer actually gets you</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {buildCategories.map(cat => (
        <article class="card-dark p-7 lg:p-8">
          <h3 class="display-h3 mb-4">{cat.title}</h3>
          <p class="text-bone-dim leading-relaxed">{cat.body}</p>
        </article>
      ))}
    </div>
    <div class="mt-12">
      <p class="text-bone-dim max-w-3xl leading-relaxed">
        Most engagements are some mix of these. A typical team Workspace looks like harness configuration plus a handful of custom skills plus one or two MCP servers wired into the tools the team already pays for. A typical custom-software engagement looks like an internal dashboard plus an integration into the client's existing CMS. The duck reads which one you need on the scoping call.
      </p>
    </div>
  </Section>

  <Section tone="cream" label="Why not Upwork or Toptal">
    <div class="prose-rdts max-w-3xl">
      <h2 class="display-h2 mb-8">Why not just hire an AI developer on Upwork or Toptal</h2>
      <p>
        Honest answer: for the right job, you should. If you need a 4-hour script to clean up a CSV, posting on Upwork or Fiverr is the right move. I do not compete on $25 one-offs and you should not pay me solo-engineer prices for one.
      </p>
      <p>
        Where the marketplace model breaks down is real engagements. The bid model rewards the lowest bid, not the best engineer, which means you spend your time filtering scammers and re-interviewing juniors with stolen portfolios. Even when you find a good freelance AI developer, the platform incentivizes them to disappear at the end of the contract — Upwork penalizes off-platform continuity, so the moment your project ships, your engineer's incentive is to be done. There is no second engagement, no model upgrade six months later, no "hey can you fix that MCP server that broke when Anthropic shipped a new SDK." You are starting over with a stranger every time.
      </p>
      <p>
        Toptal and Arc.dev solve part of this with vetted talent, and they are better than the open marketplaces. The problem there is the agency layer — you are paying retail-plus-margin to a middleman, your engineer often has three other clients, and the source code patterns are whatever the placement engineer happens to like that month. Continuity exists in theory. In practice, when your engineer rolls off, the next one starts the codebase tour from scratch.
      </p>
      <p>
        My pitch is the opposite of all of that. The duck quotes shape, scope, and price before we ever talk on a call. One engineer who knows your setup end to end. Source code, IP, repos, deploy keys, skill definitions, MCP configs — yours on ship day. If you want to fire me and bring it in-house, the codebase is structured so any competent Node engineer can take it over in an afternoon. If you want to keep me on retainer for the next pipeline, that is also there.
      </p>
      <p>
        I will not pretend I am the right hire for every job. If your build is genuinely 6 hours of work, hire someone on Upwork. If you need a team of 5 and a PM, hire an agency. If you need one focused engineer to install your AI environment or build a real piece of AI software end to end, that is the lane I built RDTS for.
      </p>
    </div>
  </Section>

  <Section tone="dark" label="What hiring me looks like">
    <h2 class="display-h2 mb-12">From first message to shipped work</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {processSteps.map(step => (
        <article class="card-dark p-7 lg:p-8">
          <div class="label label--dim mb-3">{step.label}</div>
          <h3 class="display-h3 mb-4">{step.title}</h3>
          <p class="text-bone-dim leading-relaxed">{step.body}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section tone="cream" label="Tech stack I default to">
    <div class="prose-rdts max-w-3xl">
      <h2 class="display-h2 mb-8">The stack I default to (and why)</h2>
      <p>
        I am model-agnostic and harness-agnostic in theory, very opinionated in practice. For most production AI work, I default to the <strong>Anthropic API</strong>: the frontier Claude model for anything that needs strong reasoning, content judgment, or long-context document work, and a smaller Claude variant for high-volume classification, tagging, and lightweight extraction where the frontier is overkill on cost. I reach for <strong>OpenAI's flagship GPT</strong> when it specifically wins — image understanding in a few niches, certain structured-output cases, and as a fallback when an Anthropic incident hits.
      </p>
      <p>
        For agents, I use the <strong>Claude Agent SDK</strong> when the workflow is actually agentic and the raw Anthropic API when it is not. Most "AI agents" people ask for are really one or two prompted calls with tool use — those do not need a full agent loop and pretending they do makes the system slower and more expensive. When agents are the right answer, I write <strong>MCP servers</strong> for them so the tool surface is reusable across Claude Code, Claude Desktop, Cursor, and custom agents.
      </p>
      <p>
        For harnesses, I pick what fits the team and the work: <strong>Claude Code</strong> for engineering teams that want a terminal-native loop, <strong>Cursor</strong> for teams that prefer an IDE, <strong>Codex</strong> for OpenAI-shop standardization, <strong>OpenClaw</strong> when the team wants an open alternative to Claude Code, <strong>Cline</strong> and <strong>Aider</strong> when those fit the workflow better. The harness is a tool, not a religion.
      </p>
      <p>
        On the application side: Node and TypeScript on the server (boring, debuggable, hireable), Postgres or Supabase for data (Supabase when you want auth and storage in the same place, raw Postgres when you do not), Astro for marketing sites, Next.js for apps that need real client interactivity, and Vercel for deploys. No vendor lock-in stack. Every choice picks the option another engineer can take over without a six-week ramp.
      </p>
    </div>
  </Section>

  <Section tone="cream" label="FAQ">
    <h2 class="display-h2 mb-10">Common questions about hiring an AI developer</h2>
    <div class="space-y-4 max-w-3xl">
      {faqs.map(item => (
        <details class="card-cream p-6 lg:p-7 group">
          <summary class="cursor-pointer flex justify-between items-start gap-6">
            <span class="display-h3">{item.q}</span>
            <span class="text-saffron text-2xl leading-none transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="mt-5 text-coal-dim leading-relaxed">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </Section>

  <section class="section-dark">
    <div class="container-x py-20 lg:py-28">
      <div class="max-w-3xl">
        <div class="label label--dim mb-6">Next step</div>
        <h2 class="display-h2 mb-8">
          Tell the duck what you're <span class="accent-saffron">setting up</span>
        </h2>
        <p class="text-bone-dim text-lg leading-relaxed mb-10">
          Five-minute conversation with the duck — no scoping form, no slide deck. You describe the situation, the duck reads the shape and names a price, and a brief lands in both our inboxes. If I'm wrong for it, the duck says so and points you elsewhere. You can also see ClipMango and the rest of the projects on <a href="/work/" class="link-saffron">the work page</a>.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/talk/" class="btn btn-primary">Talk to the duck →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
