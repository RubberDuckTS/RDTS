# ─── /talk duck chat — Anthropic + Resend ────────────────────────────────
# Set these in Vercel project env vars (or .env.local for local dev).
# Without them, /api/scope and /api/lead return 503.

# Anthropic API key — for Haiku scoping conversation + intake brief synthesis.
# Get one at https://console.anthropic.com → API keys.
ANTHROPIC_API_KEY=

# Resend API key — for the two outbound emails (lead → Long, spec → visitor).
# Get one at https://resend.com → API keys. Free tier covers 3K emails/mo.
RESEND_API_KEY=

# Inbox that receives lead emails (intake brief + transcript).
RDTS_INBOX=rubberducktechsolutions@gmail.com

# Verified Resend sender. Must match a domain you've verified in Resend.
# Until you verify rubberducktechsolutions.com in Resend, use the
# onboarding sandbox sender:  onboarding@resend.dev
RDTS_FROM=duck@rubberducktechsolutions.com

# Calendly link sent to visitors after they submit their spec.
CALENDLY_URL=https://calendly.com/nguy4227/let-s-connect-project-role-or-collaboration
